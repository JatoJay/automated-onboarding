generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  MANAGER
  HR
  ADMIN
  ORG_ADMIN
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TaskType {
  DOCUMENT
  FORM
  TRAINING
  MEETING
  APPROVAL
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum DocumentStatus {
  PENDING
  PROCESSING
  INDEXED
  FAILED
}

enum DocumentType {
  PDF
  DOCX
  TXT
  MD
  HTML
  URL
  CODE
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  domain      String?
  logo        String?
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users              User[]
  departments        Department[]
  knowledgeDocuments KnowledgeDocument[]
  dataSources        DataSource[]
  employeeInvites    EmployeeInvite[]
  forms              Form[]
  helpRequests       HelpRequest[]
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole      @default(EMPLOYEE)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization     Organization?   @relation(fields: [organizationId], references: [id])
  employee         Employee?
  managedEmployees Employee[]      @relation("ManagerRelation")
  chatMessages     ChatMessage[]
  taskAssignments  Task[]          @relation("AssignedBy")
  createdInvites   EmployeeInvite[]
  headOfDepartments Department[]   @relation("DepartmentHead")
  createdForms     Form[]
  assignedHelpRequests HelpRequest[] @relation("HelpRequestAssignee")
  helpRequestReplies   HelpRequestReply[]
}

model Department {
  id               String   @id @default(cuid())
  name             String
  organizationId   String
  description      String?
  parentId         String?
  headId           String?
  createdAt        DateTime @default(now())

  organization       Organization              @relation(fields: [organizationId], references: [id])
  parent             Department?               @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children           Department[]              @relation("DepartmentHierarchy")
  head               User?                     @relation("DepartmentHead", fields: [headId], references: [id])
  employees          Employee[]
  onboardingPlans    OnboardingPlan[]
  knowledgeDocuments KnowledgeDocument[]
  dataSources        DataSource[]
  employeeAccess     EmployeeDepartmentAccess[]
  employeeInvites    EmployeeInvite[]
  forms              Form[]

  @@unique([name, organizationId])
  @@index([parentId])
  @@index([headId])
}

model Employee {
  id               String           @id @default(cuid())
  userId           String?          @unique
  departmentId     String
  managerId        String?
  jobTitle         String
  startDate        DateTime
  onboardingStatus OnboardingStatus @default(NOT_STARTED)
  firstName        String?
  lastName         String?
  email            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User?                      @relation(fields: [userId], references: [id])
  department       Department                 @relation(fields: [departmentId], references: [id])
  manager          User?                      @relation("ManagerRelation", fields: [managerId], references: [id])
  tasks            Task[]
  departmentAccess EmployeeDepartmentAccess[]
  formSubmissions  FormSubmission[]
  helpRequests     HelpRequest[]
}

model EmployeeDepartmentAccess {
  id           String   @id @default(cuid())
  employeeId   String
  departmentId String
  grantedById  String?
  grantedAt    DateTime @default(now())

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([employeeId, departmentId])
  @@index([employeeId])
  @@index([departmentId])
}

model OnboardingPlan {
  id           String   @id @default(cuid())
  name         String
  description  String?
  departmentId String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department    Department?    @relation(fields: [departmentId], references: [id])
  taskTemplates TaskTemplate[]
}

model TaskTemplate {
  id               String   @id @default(cuid())
  onboardingPlanId String
  title            String
  description      String?
  type             TaskType
  daysFromStart    Int      @default(0)
  durationDays     Int      @default(1)
  order            Int      @default(0)
  isRequired       Boolean  @default(true)
  attachedFormId   String?
  attachedDocId    String?
  attachedUrl      String?
  createdAt        DateTime @default(now())

  onboardingPlan OnboardingPlan     @relation(fields: [onboardingPlanId], references: [id])
  dependencies   TaskTemplate[]     @relation("TaskDependencies")
  dependentOn    TaskTemplate[]     @relation("TaskDependencies")
  attachedForm   Form?              @relation(fields: [attachedFormId], references: [id])
  attachedDoc    KnowledgeDocument? @relation(fields: [attachedDocId], references: [id])

  @@index([attachedFormId])
  @@index([attachedDocId])
}

model Task {
  id           String     @id @default(cuid())
  employeeId   String
  title        String
  description  String?
  type         TaskType
  status       TaskStatus @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  assignedById String?
  metadata     Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  employee     Employee      @relation(fields: [employeeId], references: [id])
  assignedBy   User?         @relation("AssignedBy", fields: [assignedById], references: [id])
  helpRequests HelpRequest[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  sources   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DataSource {
  id             String   @id @default(cuid())
  organizationId String
  departmentId   String?
  isOrgWide      Boolean  @default(false)
  name           String
  type           String
  config         Json?
  lastSyncAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id])
  department         Department?         @relation(fields: [departmentId], references: [id])
  knowledgeDocuments KnowledgeDocument[]

  @@index([departmentId])
}

model KnowledgeDocument {
  id             String         @id @default(cuid())
  organizationId String
  departmentId   String?
  dataSourceId   String?
  title          String
  content        String
  category       String
  documentType   DocumentType   @default(TXT)
  status         DocumentStatus @default(PENDING)
  fileUrl        String?
  fileSize       Int?
  chunkCount     Int            @default(0)
  errorMessage   String?
  metadata       Json?
  isOrgWide      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id])
  department    Department?     @relation(fields: [departmentId], references: [id])
  dataSource    DataSource?     @relation(fields: [dataSourceId], references: [id])
  chunks        DocumentChunk[]
  taskTemplates TaskTemplate[]

  @@index([departmentId])
  @@index([organizationId, departmentId])
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  content    String
  chunkIndex Int
  tokenCount Int?
  qdrantId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model EmployeeInvite {
  id             String    @id @default(cuid())
  token          String    @unique @default(cuid())
  email          String
  firstName      String
  lastName       String
  jobTitle       String
  departmentId   String
  managerId      String?
  startDate      DateTime
  organizationId String
  createdById    String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  department   Department   @relation(fields: [departmentId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([token])
  @@index([email])
}

enum FormStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum HelpRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum HelpRequestCategory {
  TASK_BLOCKED
  QUESTION
  TECHNICAL_ISSUE
  ACCESS_REQUEST
  OTHER
}

enum FormFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  CHECKBOX
  FILE
  EMAIL
  PHONE
}

model Form {
  id             String     @id @default(cuid())
  organizationId String
  departmentId   String?
  name           String
  description    String?
  isOrgWide      Boolean    @default(true)
  status         FormStatus @default(DRAFT)
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  department   Department?      @relation(fields: [departmentId], references: [id])
  createdBy      User             @relation(fields: [createdById], references: [id])
  fields         FormField[]
  submissions    FormSubmission[]
  taskTemplates  TaskTemplate[]

  @@index([organizationId])
  @@index([departmentId])
}

model FormField {
  id           String        @id @default(cuid())
  formId       String
  label        String
  type         FormFieldType
  placeholder  String?
  helpText     String?
  required     Boolean       @default(false)
  options      Json?
  validation   Json?
  order        Int           @default(0)
  createdAt    DateTime      @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

model FormSubmission {
  id          String   @id @default(cuid())
  formId      String
  employeeId  String
  data        Json
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form     Form     @relation(fields: [formId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([formId, employeeId])
  @@index([formId])
  @@index([employeeId])
}

model HelpRequest {
  id             String              @id @default(cuid())
  organizationId String
  employeeId     String
  taskId         String?
  category       HelpRequestCategory
  subject        String
  description    String
  status         HelpRequestStatus   @default(OPEN)
  assignedToId   String?
  resolvedAt     DateTime?
  resolution     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])
  task         Task?        @relation(fields: [taskId], references: [id])
  assignedTo   User?        @relation("HelpRequestAssignee", fields: [assignedToId], references: [id])
  replies      HelpRequestReply[]

  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
}

model HelpRequestReply {
  id            String   @id @default(cuid())
  helpRequestId String
  userId        String
  message       String
  createdAt     DateTime @default(now())

  helpRequest HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([helpRequestId])
}
